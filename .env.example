# API Configuration - Choose one of the following:

# Option 1: Direct Anthropic API (recommended for Anthropic models)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# MOODLE_AI_BASE_URL=https://api.anthropic.com
# MODEL=claude-sonnet-4.6

# Option 2: Moodle AI Proxy (OpenAI-compatible)
# ANTHROPIC_API_KEY=your-moodle-proxy-key-here
# MODEL=claude-sonnet-4.6

# Option 3: Azure OpenAI / GitHub Copilot Models
# ANTHROPIC_API_KEY=your-azure-api-key-here
# MOODLE_AI_BASE_URL=https://your-resource.openai.azure.com
# MODEL=gpt-4o  # Use Azure-compatible model

# Moodle QA Site
MOODLE_QA_URL=https://your-qa-site.moodledemo.net
